<form class="countdown-dice-config-form">
  <div class="form-row">
    <div class="form-field">
      <label for="dice-name">{{localize 'VAGABOND.CountdownDice.Name'}}</label>
      <input
        type="text"
        id="dice-name"
        name="name"
        value="{{name}}"
        required
        placeholder="{{localize 'VAGABOND.CountdownDice.Name'}}"
      />
    </div>
  </div>

  <div class="form-row">
    <div class="form-field">
      <label for="dice-type">{{localize 'VAGABOND.CountdownDice.DiceType'}}</label>
      <select id="dice-type" name="diceType">
        {{#each diceTypes as |type|}}
          <option value="{{type}}" {{#if (eq type ../diceType)}}selected{{/if}}>
            {{type}}
          </option>
        {{/each}}
      </select>
    </div>

    <div class="form-field">
      <label for="dice-size">{{localize 'VAGABOND.CountdownDice.Size'}}</label>
      <select id="dice-size" name="size">
        <option value="S" {{#if (eq size "S")}}selected{{/if}}>{{localize "VAGABOND.UI.Labels.SmallSize"}}</option>
        <option value="M" {{#if (eq size "M")}}selected{{/if}}>{{localize "VAGABOND.UI.Labels.MediumSize"}}</option>
        <option value="L" {{#if (eq size "L")}}selected{{/if}}>{{localize "VAGABOND.UI.Labels.LargeSize"}}</option>
      </select>
    </div>
  </div>

  {{#unless isEdit}}
  <div class="form-row">
    <div class="form-field">
      <label>
        <input type="checkbox" name="isBurning" id="is-burning" {{#if isBurning}}checked{{/if}} />
        <i class="fas fa-fire"></i> Burning Die (deals damage each round)
      </label>
    </div>
  </div>

  <div class="burning-options" id="burning-options" style="{{#unless isBurning}}display:none{{/unless}}">
    <div class="form-row">
      <div class="form-field">
        <label for="damage-type">Damage Type</label>
        <select id="damage-type" name="damageType">
          {{#each burningDamageTypes as |label key|}}
            <option value="{{key}}" {{#if (eq key ../selectedDamageType)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-field">
        <label for="target-token">Target Token</label>
        <select id="target-token" name="targetTokenId">
          <option value="">— None (manual) —</option>
          {{#each tokens as |token|}}
            <option value="{{token.id}}" {{#if (eq token.id ../selectedTokenId)}}selected{{/if}}>
              {{token.name}}
            </option>
          {{/each}}
        </select>
      </div>
    </div>
  </div>
  {{/unless}}

  <footer class="form-footer">
    <button type="button" data-action="cancel">
      <i class="fas fa-times"></i> {{localize 'Cancel'}}
    </button>
    <button type="submit" class="default">
      <i class="fas fa-check"></i> {{#if isEdit}}{{localize 'Update'}}{{else}}{{localize 'Create'}}{{/if}}
    </button>
  </footer>
</form>
